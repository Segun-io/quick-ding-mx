# ── Infrastructure (always runs) ────────────────────────────────────
# Used by: mariadb, minio, invoiceninja

MYSQL_ROOT_PASSWORD=rootpassword
SALAMANCA_DB_PASSWORD=salamancapassword

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# InvoiceNinja
INVOICENINJA_APP_URL=http://localhost:8080
INVOICENINJA_APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
IN_USER_EMAIL=admin@example.com
IN_PASSWORD=changeme
INVOICENINJA_API_TOKEN=your_invoiceninja_api_token

# ── Containerized salamanca (--profile full only) ───────────────────
# Only needed when running `docker compose --profile full up`

WEBHOOK_SECRET=your_webhook_secret_min_16_chars
SALAMANCA_HOST_PORT=3002

# Facturama
FACTURAMA_ENV=sandbox
FACTURAMA_USER=your_facturama_user
FACTURAMA_PASSWORD=your_facturama_password

# CFDI Issuer
ISSUER_RFC=EKU9003173C9
ISSUER_NAME=ESCUELA KEMPER URGATE
ISSUER_FISCAL_REGIME=601
ISSUER_EXPEDITION_PLACE=06600

# Salamanca Auth
BETTER_AUTH_SECRET=your_better_auth_secret_at_least_32_characters_long
CORS_ORIGIN=http://localhost:3001
