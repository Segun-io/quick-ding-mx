# ── MariaDB ───────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
SALAMANCA_DB_PASSWORD=salamancapassword

# ── MinIO (S3-compatible object storage) ──────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── InvoiceNinja ──────────────────────────────────────────────────────
# Public URL where InvoiceNinja is accessible
INVOICENINJA_APP_URL=http://localhost:8080

# APP_KEY — Required. Generate with:
#   docker run --rm invoiceninja/invoiceninja:5 php artisan key:generate --show
# Paste the full output including the "base64:" prefix.
INVOICENINJA_APP_KEY=

# Set to false and REQUIRE_HTTPS to true for production
INVOICENINJA_APP_DEBUG=true
INVOICENINJA_REQUIRE_HTTPS=false

# Initial admin account (only used on first run)
IN_USER_EMAIL=admin@example.com
IN_PASSWORD=changeme

# ── Salamanca ↔ InvoiceNinja integration ──────────────────────────────
# API token for Salamanca to call InvoiceNinja.
# Generate after first login: InvoiceNinja UI → Settings → Account Management
#   → API Tokens → Add Token. Copy the token here.
INVOICENINJA_API_TOKEN=

# ── Containerized salamanca (--profile full only) ─────────────────────
# Only needed when running `docker compose --profile full up`

# Shared secret for the InvoiceNinja → Salamanca webhook. Min 16 characters.
# Generate with:  openssl rand -hex 16
WEBHOOK_SECRET=

SALAMANCA_HOST_PORT=3002

# ── Facturama (CFDI provider) ─────────────────────────────────────────
FACTURAMA_ENV=sandbox
FACTURAMA_USER=
FACTURAMA_PASSWORD=

# ── CFDI Issuer (your company tax info) ───────────────────────────────
# Defaults below are Facturama's sandbox test RFC
ISSUER_RFC=EKU9003173C9
ISSUER_NAME=ESCUELA KEMPER URGATE
ISSUER_FISCAL_REGIME=601
ISSUER_EXPEDITION_PLACE=06600

# ── Salamanca Auth ────────────────────────────────────────────────────
# Secret for BetterAuth session signing. Min 32 characters.
# Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:3001
